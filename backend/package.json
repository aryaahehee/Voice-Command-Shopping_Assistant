{
  "name": "voice-shopping-assistant-backend",
  "version": "0.1.0",
  "private": true,
  "description": "VoiceCart — Express + TypeScript REST API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "express": "4.21.2",
    "cors": "2.8.5",
    "helmet": "8.0.0",
    "morgan": "1.10.0",
    "dotenv": "16.4.7",
    "mongoose": "8.9.3",
    "bcryptjs": "2.4.3",
    "jsonwebtoken": "9.0.2",
    "express-validator": "7.2.1",
    "express-rate-limit": "7.5.0",
    "compression": "1.7.4",
    "uuid": "11.0.3",
    "openai": "4.77.0",
    "date-fns": "4.1.0",
    "winston": "3.17.0",
    "winston-daily-rotate-file": "5.0.0"
  },
  "devDependencies": {
    "typescript": "5.7.2",
    "@types/express": "5.0.0",
    "@types/cors": "2.8.17",
    "@types/morgan": "1.9.9",
    "@types/bcryptjs": "2.4.6",
    "@types/jsonwebtoken": "9.0.7",
    "@types/compression": "1.7.5",
    "@types/uuid": "10.0.0",
    "@types/node": "22.10.2",
    "ts-node-dev": "2.0.0",
    "ts-node": "10.9.2",
    "@typescript-eslint/eslint-plugin": "8.18.2",
    "@typescript-eslint/parser": "8.18.2",
    "eslint": "9.17.0",
    "jest": "29.7.0",
    "@types/jest": "29.5.14",
    "@types/supertest": "6.0.2",
    "supertest": "7.0.0",
    "ts-jest": "29.2.5"
  }
}
